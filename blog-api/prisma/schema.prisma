generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(50)
  email     String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  nickname  String?  @db.VarChar(100)
  avatar    String?  @db.VarChar(255)
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  posts     Post[]

  @@map("users")
}

enum Role {
  ADMIN
  EDITOR
}

model Post {
  id          Int        @id @default(autoincrement())
  title       String     @db.VarChar(255)
  slug        String     @unique @db.VarChar(255)
  excerpt     String?    @db.Text
  content     String     @db.LongText
  coverImage  String?    @db.VarChar(255) @map("cover_image")
  status      PostStatus @default(DRAFT)
  viewCount   Int        @default(0) @map("view_count")
  publishedAt DateTime?  @map("published_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  authorId    Int        @map("author_id")
  author      User       @relation(fields: [authorId], references: [id])

  categoryId  Int?       @map("category_id")
  category    Category?  @relation(fields: [categoryId], references: [id])

  tags        PostTag[]
  comments    Comment[]

  @@index([slug])
  @@index([status, publishedAt])
  @@map("posts")
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  posts       Post[]

  @@map("categories")
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(50)
  slug      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  posts     PostTag[]

  @@map("tags")
}

model PostTag {
  postId    Int      @map("post_id")
  tagId     Int      @map("tag_id")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

model Comment {
  id          Int           @id @default(autoincrement())
  authorName  String        @db.VarChar(100)
  authorEmail String        @db.VarChar(100)
  content     String        @db.Text
  status      CommentStatus @default(PENDING)
  createdAt   DateTime      @default(now()) @map("created_at")

  postId      Int           @map("post_id")
  post        Post          @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("comments")
}

enum CommentStatus {
  PENDING
  APPROVED
  SPAM
}

model Media {
  id           Int      @id @default(autoincrement())
  filename     String   @db.VarChar(255)
  originalName String   @db.VarChar(255) @map("original_name")
  mimeType     String   @db.VarChar(100) @map("mime_type")
  size         Int
  url          String   @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("media")
}

model ViewLog {
  id        Int      @id @default(autoincrement())
  postId    Int?     @map("post_id")
  ip        String   @db.VarChar(45)
  userAgent String?  @db.Text @map("user_agent")
  path      String   @db.VarChar(255)
  visitedAt DateTime @default(now()) @map("visited_at")

  @@index([postId, visitedAt])
  @@index([path, visitedAt])
  @@map("view_logs")
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
